{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Folha360": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=folha360;Username=folha360_user;Password=Folha360@Dev",
    "Redis": "localhost:6379,password=Folha360@Dev",
    "RabbitMQ": "amqp://folha360:Folha360@Dev@localhost:5672"
  },
  "Jwt": {
    "Secret": "Folha360@DevSecretKey@2026!TempKey",
    "Issuer": "Folha360",
    "Audience": "Folha360.Api"
  },
  "Seq": {
    "Url": "http://localhost:5341"
  },
  "MinIO": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "Bucket": "folha360-documentos"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}